# Test Environment Configuration Template
# Copy this file to .env.test for integration testing

# ==============================================
# LLM Configuration
# ==============================================
# Provider: openai, watsonx, anthropic
LLM_PROVIDER=openai
LLM_MODEL=gpt-4
LLM_API_KEY=your-test-api-key-here

# Optional: Custom base URL
# LLM_BASE_URL=https://api.example.com/v1

# ==============================================
# Watsonx-specific (if using watsonx)
# ==============================================
# WATSONX_PROJECT_ID=your-project-id
# WATSONX_URL=https://us-south.ml.cloud.ibm.com
# WATSONX_APIKEY=your-watsonx-api-key

# ==============================================
# OpenAI-specific (if using openai)
# ==============================================
# OPENAI_API_KEY=your-openai-api-key
# OPENAI_BASE_URL=https://api.openai.com/v1

# ==============================================
# Anthropic-specific (if using anthropic)
# ==============================================
# ANTHROPIC_API_KEY=your-anthropic-api-key
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# ==============================================
# Logging Configuration
# ==============================================
LOG_LEVEL=DEBUG
LOG_FORMAT=text

# ==============================================
# Usage Instructions
# ==============================================
# 1. Copy this file: cp .env.test.template .env.test
# 2. Fill in your test API keys
# 3. Run integration tests: mise run test-integration
# 4. NEVER commit .env.test (it's in .gitignore)
