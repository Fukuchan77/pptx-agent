# Ollama Test Configuration for granite4:latest
# This file is for testing Ollama connectivity

# Environment
ENVIRONMENT=development

# LLM Provider Configuration
LLM_PROVIDER=openai
LLM_MODEL=granite4:latest
LLM_API_BASE=http://localhost:11434/v1

# Ollama doesn't require authentication, but the system needs some value
OPENAI_API_KEY=ollama-local-key

# Request Timeouts
MAX_RETRIES=3
REQUEST_TIMEOUT=120
