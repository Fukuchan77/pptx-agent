# Environment Configuration Template
# Copy this file to .env and fill in your values

# --- General Settings ---
# "development" or "production"
ENVIRONMENT=development

# --- LLM Provider Selection ---
# Supported values: "openai", "anthropic", "watsonx"
LLM_PROVIDER=openai

# Model Selection
# OpenAI examples: "gpt-4-turbo-preview", "gpt-3.5-turbo", "gpt-4o"
# Anthropic examples: "claude-3-5-sonnet-20241022", "claude-3-opus-20240229"
# Watsonx examples: "ibm/granite-13b-chat-v2", "meta-llama/llama-3-70b-instruct"
LLM_MODEL=gpt-4o

# --- Provider Specific Settings ---

# 1. OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key
# LLM_API_BASE=http://localhost:11434/v1 # Optional: Use for local Ollama endpoints

# 2. Anthropic Configuration (Required if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=your-anthropic-api-key

# 3. IBM watsonx Configuration (Required if LLM_PROVIDER=watsonx)
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_APIKEY=your-watsonx-api-key
WATSONX_PROJECT_ID=your-project-id

# --- Production Fallback Settings ---
# Automatically enabled in "production" environment
ENABLE_FALLBACK=false
FALLBACK_PROVIDER=anthropic
FALLBACK_MODEL=claude-3-5-sonnet-20241022

# --- Request Timeouts and Limitations ---
# MAX_RETRIES=3
# REQUEST_TIMEOUT=120
# MAX_REQUESTS=20
# MAX_RESPONSE_TOKENS=50000
